{
  "optimizer": {
    "direction": "minimize",
    "seed": 1337
  },
  "search_space": {
    "snapControls.tolerance": {
      "type": "float",
      "low": 0.2,
      "high": 1.0
    },
    "snapControls.nSolveIter": {
      "type": "int",
      "low": 50,
      "high": 1000
    },
    "snapControls.nSmoothPatch": {
      "type": "int",
      "low": 5,
      "high": 25
    },
    "snapControls.nRelaxIter": {
      "type": "int",
      "low": 3,
      "high": 15
    },
    "snapControls.nFeatureSnapIter": {
      "type": "int",
      "low": 0,
      "high": 15
    },
    "castellatedMeshControls.nCellsBetweenLevels": {
      "type": "categorical",
      "choices": [
        2,
        3,
        4
      ]
    }
  },
  "score_spec": {
    "intent": "Keep scoring simple with a strong priority on underdetermined cells and strict gating on a few other metrics. Any trial with cellCount > 250k gets a heavy penalty (but still recorded).",
    "acceptance_thresholds": {
      "N_underdeterminedCells": "< 10",
      "N_lowWeightFaces": "== 0",
      "N_faces_nonOrtho_gt_70": "< 100",
      "N_warpedFaces": "< 5",
      "total_cells": "<= 250000"
    },
    "scalar_score_definition": {
      "description": "Lower is better. Heavily penalize underdetermined cells first; then apply penalties for constraint violations; then mild penalties for non-ortho/warped even if within thresholds. Always include cell-count penalty if above 250k.",
      "formula_pseudocode": [
        "score = 0",
        "score += 1000 * max(0, N_underdeterminedCells - 9) + 50 * N_underdeterminedCells",
        "score += 10000 * max(0, N_lowWeightFaces)  # hard penalty if any",
        "score += 50 * max(0, N_faces_nonOrtho_gt_70 - 99) + 0.5 * N_faces_nonOrtho_gt_70",
        "score += 200 * max(0, N_warpedFaces - 4) + 2.0 * N_warpedFaces",
        "if total_cells > 250000: score += 0.1 * (total_cells - 250000) + 20000"
      ],
      "notes": [
        "This structure makes underdetermined cells dominant.",
        "Hard-ish penalties discourage any lowWeightFaces.",
        "Non-ortho/warped thresholds are enforced but not made impossible.",
        "Cell count above 250k is allowed but strongly discouraged."
      ]
    }
  },
  "editing_snappyHexMeshDict": {
    "required_replacements": [
      {
        "key": "tolerance",
        "block": "snapControls",
        "regex": "(?ms)(snapControls\\s*\\{.*?\\btolerance\\s+)([^;\\n]+)(;)",
        "replacement": "\\g<1>{tolerance}\\g<3>"
      },
      {
        "key": "nSolveIter",
        "block": "snapControls",
        "regex": "(?ms)(snapControls\\s*\\{.*?\\bnSolveIter\\s+)(\\d+)(;)",
        "replacement": "\\g<1>{nSolveIter}\\g<3>"
      },
      {
        "key": "nSmoothPatch",
        "block": "snapControls",
        "regex": "(?ms)(snapControls\\s*\\{.*?\\bnSmoothPatch\\s+)(\\d+)(;)",
        "replacement": "\\g<1>{nSmoothPatch}\\g<3>"
      },
      {
        "key": "nRelaxIter",
        "block": "snapControls",
        "regex": "(?ms)(snapControls\\s*\\{.*?\\bnRelaxIter\\s+)(\\d+)(;)",
        "replacement": "\\g<1>{nRelaxIter}\\g<3>"
      },
      {
        "key": "nFeatureSnapIter",
        "block": "snapControls",
        "regex": "(?ms)(snapControls\\s*\\{.*?\\bnFeatureSnapIter\\s+)(\\d+)(;)",
        "replacement": "\\g<1>{nFeatureSnapIter}\\g<3>"
      },
      {
        "key": "nCellsBetweenLevels",
        "block": "castellatedMeshControls",
        "regex": "(?ms)(castellatedMeshControls\\s*\\{.*?\\bnCellsBetweenLevels\\s+)(\\d+)(;)",
        "replacement": "\\g<1>{nCellsBetweenLevels}\\g<3>"
      }
    ]
  },
  "log_parsing_regex": {
    "N_faces_nonOrtho_gt_70": "\\*Number of severely non-orthogonal \\(> 70 degrees\\) faces:\\s*(\\d+)",
    "N_warpedFaces": "\\*There are\\s*(\\d+)\\s*faces with ratio between projected and actual area < 0\\.8",
    "N_underdeterminedCells": "Cells with small determinant \\(< 0\\.001\\) found, number of cells:\\s*(\\d+)",
    "N_lowWeightFaces": "Faces with small interpolation weight \\(< 0\\.05\\) found, number of faces:\\s*(\\d+)",
    "total_cells_patterns": [
      "Mesh has\\s+(\\d+)\\s+cells",
      "cells:\\s*(\\d+)"
    ]
  }
}
