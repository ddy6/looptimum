---
interface Props {
  title: string;
  src: string;
  alt: string;
  summary: string;
}

const { title, src, alt, summary } = Astro.props;
---

<article class="plot-card reveal">
  <div class="plot-card-copy">
    <p class="eyebrow">Derived public evidence</p>
    <h3>{title}</h3>
    <p>{summary}</p>
  </div>
  <img loading="lazy" src={src} alt={alt} />
</article>
