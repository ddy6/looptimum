---
import ActionPanel from "../components/ActionPanel.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { intakeQuestions, repoLinks, siteConfig } from "../data/site";
---

<BaseLayout
  title="Pilot Intake | Looptimum"
  description="Start a Looptimum fit review with the minimum information needed to evaluate a bounded pilot for optimum trial targeting."
  currentPath="/pilot/"
>
  <PageHero
    eyebrow="Pilot intake"
    title="Start with the loop that is already expensive enough to deserve attention."
    dek="A useful first conversation is short: what is being optimized, how expensive is one run, where does it execute, and what constraints cannot be violated."
    spacedBelow={true}
    primaryHref={siteConfig.contactHref}
    primaryLabel="Email fit review"
    secondaryHref={repoLinks.intake}
    secondaryLabel="Read technical intake notes"
  />

  <div class="stack-lg">
    <section class="two-column">
      <div class="feature-panel reveal">
        <p class="eyebrow">What to send</p>
        <h2>These answers are usually enough to decide whether a pilot is worth scoping.</h2>
        <p>
          The intake prompts below are intended to help guide initial fit
          assessment of your project. Short, concrete answers are helpful for a
          first screening.
        </p>
        <div class="hero-actions">
          <a class="button button-primary" href={siteConfig.contactHref}>
            {siteConfig.contactEmail}
          </a>
          <a class="button button-secondary" href={repoLinks.pilot}>Pilot framing in repo</a>
        </div>
      </div>
      <div class="question-grid">
        {intakeQuestions.map((question) => (
          <article class="question-card reveal">
            <p class="eyebrow">Intake prompt</p>
            <h3>{question}</h3>
          </article>
        ))}
      </div>
    </section>

    <section class="stack-md">
      <div class="section-head reveal">
        <p class="eyebrow">Fit signals</p>
        <h2>What a strong first Looptimum project looks like.</h2>
        <p>These are the characteristics that usually indicate a good early fit.</p>
      </div>

      <section class="criteria-grid">
        <article class="criteria-card reveal">
          <h3>Best early pilot</h3>
          <p>
            One loop, one scalar objective, bounded knobs.
          </p>
        </article>
        <article class="criteria-card reveal">
          <h3>Security posture</h3>
          <p>
            Looptimum is strongest where execution must stay in a client-owned or
            restricted environment instead of moving to a hosted service.
          </p>
        </article>
        <article class="criteria-card reveal">
          <h3>What the example demonstrates</h3>
          <p>
            The example case outlines an end-to-end validated
            outcome: fewer trials, lighter mesh, faster solve, and preserved
            behavior.
          </p>
        </article>
        <article class="criteria-card reveal">
          <h3>What happens next</h3>
          <p>
            If Looptimum might fit your project, the next step is to get in
            touch, or explore Looptimum on GitHub.
          </p>
        </article>
      </section>
    </section>

    <ActionPanel
      title="Check whether Looptimum fits your project."
      body="Explore the technical details, review the validated case study, or get in touch."
      primaryHref="/evidence/"
      primaryLabel="Review case study"
      secondaryHref={repoLinks.caseStudy}
      secondaryLabel="GitHub"
    />
  </div>
</BaseLayout>
