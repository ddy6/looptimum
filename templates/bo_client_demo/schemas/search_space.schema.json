{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SearchSpace",
  "type": "object",
  "required": ["parameters"],
  "properties": {
    "parameters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "type", "bounds"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": ["float", "int"]
          },
          "bounds": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "items": {
              "type": "number"
            }
          },
          "description": {
            "type": "string"
          }
        }
      }
    }
  }
}
