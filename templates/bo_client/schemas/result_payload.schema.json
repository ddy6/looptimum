{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IngestPayload",
  "description": "Deprecated compatibility alias for ingest_payload.schema.json. Scheduled for removal in v0.4.0.",
  "x-deprecated-alias-for": "ingest_payload.schema.json",
  "type": "object",
  "required": ["trial_id", "params", "objectives"],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$"
    },
    "trial_id": {
      "type": "integer",
      "minimum": 1
    },
    "params": {
      "type": "object"
    },
    "objectives": {
      "type": "object",
      "additionalProperties": {
        "type": ["number", "null"]
      }
    },
    "status": {
      "type": "string",
      "enum": ["ok", "failed", "killed", "timeout", "success"]
    },
    "penalty_objective": {
      "type": "number"
    },
    "terminal_reason": {
      "type": "string"
    },
    "heartbeat_at": {
      "type": "number"
    },
    "heartbeat_note": {
      "type": "string"
    },
    "heartbeat_meta": {
      "type": "object"
    }
  }
}
